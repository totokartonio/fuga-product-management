# Server
NODE_ENV=development
PORT=3000

# Database (local dev points at Compose Postgres via localhost)
DATABASE_URL=postgresql://fuga:fuga@localhost:5432/fuga

# Redis
REDIS_URL=redis://localhost:6379

# MinIO / object storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=covers
MINIO_USE_SSL=false
# MINIO_PUBLIC_ENDPOINT only needed when server runs in Docker
# (browser-reachable host for cover URLs); omit for local dev